---
import AdminLayout from "../../layouts/AdminLayout.astro";
import galleryData from "../../data/gallery.json";

const images = galleryData.images;
---

<AdminLayout title="Dashboard — Créati'Clo">
  <div class="min-h-screen bg-neutral-50">
    <!-- Header admin -->
    <header
      class="bg-white border-b border-neutral-100 px-6 py-4 flex items-center justify-between sticky top-0 z-10"
    >
      <div class="flex items-center gap-4">
        <img src="/logo.svg" alt="Créati'Clo" class="h-6" />
        <span class="text-xs text-neutral-400 tracking-widest uppercase"
          >Administration</span
        >
      </div>
      <div class="flex items-center gap-3">
        <button
          id="publish-btn"
          disabled
          class="relative flex items-center gap-2 bg-neutral-100 text-neutral-400 px-4 py-2 rounded-full text-sm transition-all duration-200 disabled:cursor-not-allowed"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-4 h-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="17 8 12 3 7 8"></polyline>
            <line x1="12" y1="3" x2="12" y2="15"></line>
          </svg>
          Publier
          <span
            id="publish-badge"
            class="hidden absolute -top-1.5 -right-1.5 bg-pink-500 text-white text-xs rounded-full w-5 h-5 flex items-center justify-center font-medium"
          ></span>
        </button>
        <button
          id="logout-btn"
          class="text-sm text-neutral-500 hover:text-pink-500 transition-colors duration-200"
        >
          Se déconnecter
        </button>
      </div>
    </header>

    <!-- Contenu -->
    <main class="max-w-6xl mx-auto px-6 py-12 flex flex-col gap-12">
      <!-- Titre -->
      <div class="flex flex-col gap-2">
        <h1 class="text-3xl font-serif text-neutral-800">Galerie</h1>
        <p class="text-neutral-500 text-sm">
          Gérez les photos de votre atelier.
        </p>
      </div>

      <!-- Grille -->
      <div
        class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4"
        id="gallery-grid"
      >
        {
          images.map(({ id, src, alt, description, featured }) => (
            <div
              class="bg-white rounded-2xl overflow-hidden shadow-sm border border-neutral-100"
              data-id={id}
            >
              <div class="aspect-[3/4] overflow-hidden">
                <img src={src} alt={alt} class="w-full h-full object-cover" />
              </div>
              <div class="p-3 flex flex-col gap-2">
                <p class="text-xs text-neutral-600 truncate">{alt}</p>
                <div class="flex items-center justify-around pt-1">
                  <button
                    class="edit-btn p-2 rounded-xl hover:bg-pink-50 transition-colors"
                    data-id={id}
                    data-alt={alt}
                    data-description={description}
                    data-featured={featured}
                    data-src={src}
                    title="Modifier"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="w-4 h-4 text-pink-500"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                      <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                    </svg>
                  </button>
                  <button
                    class="delete-btn p-2 rounded-xl hover:bg-red-50 transition-colors"
                    data-id={id}
                    data-src={src}
                    data-alt={alt}
                    title="Supprimer"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="w-4 h-4 text-red-500"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <polyline points="3 6 5 6 21 6" />
                      <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
                      <path d="M10 11v6M14 11v6" />
                      <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2" />
                    </svg>
                  </button>
                  <button
                    class="featured-btn p-2 rounded-xl hover:bg-yellow-50 transition-colors"
                    data-id={id}
                    data-featured={featured}
                    title={
                      featured
                        ? "Retirer de la page d'accueil"
                        : "Mettre en vedette"
                    }
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class={`w-4 h-4 transition-colors ${featured ? "text-yellow-400 fill-yellow-400" : "text-yellow-400"}`}
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z" />
                    </svg>
                  </button>
                </div>
              </div>
            </div>
          ))
        }

        <!-- Zone d'ajout -->
        <div
          id="upload-zone"
          class="aspect-[3/4] border-2 border-dashed border-neutral-200 rounded-2xl flex flex-col items-center justify-center gap-2 cursor-pointer hover:border-pink-400 hover:bg-pink-50/30 transition-colors duration-200"
        >
          <span class="text-3xl text-neutral-300">+</span>
          <span class="text-xs text-neutral-400">Ajouter une photo</span>
        </div>
      </div>
    </main>
  </div>

  <!-- Modale modification -->
  <div
    id="edit-modal"
    class="hidden fixed inset-0 z-50 bg-black/50 backdrop-blur-sm flex items-center justify-center p-4"
  >
    <div
      class="bg-white rounded-2xl w-full max-w-md flex flex-col max-h-[90vh]"
    >
      <div class="flex items-center justify-between p-6 pb-4">
        <h2 class="text-lg font-serif text-neutral-800">Modifier la photo</h2>
        <button
          id="close-edit"
          class="text-neutral-400 hover:text-pink-500 transition-colors"
          >✕</button
        >
      </div>
      <div class="flex flex-col gap-4 px-6 overflow-y-auto">
        <input type="hidden" id="edit-id" />

        <div class="flex flex-col gap-2">
          <label class="text-sm text-neutral-600">Photo</label>
          <button
            type="button"
            id="edit-change-photo"
            class="border border-neutral-200 rounded-xl px-4 py-3 text-sm text-neutral-500 hover:border-pink-400 hover:text-pink-500 transition-colors text-left"
          >
            📷 Changer la photo (optionnel)
          </button>
          <input
            type="file"
            id="edit-file-input"
            accept="image/*"
            class="hidden"
          />
        </div>

        <div id="edit-cropper-container" class="hidden flex flex-col gap-3">
          <div
            class="relative w-full bg-neutral-100 rounded-xl overflow-hidden"
            style="height: 280px;"
          >
            <img id="edit-cropper-image" src="" alt="Crop" class="max-w-full" />
          </div>
          <div class="flex items-center justify-center gap-2">
            <button
              type="button"
              id="edit-zoom-in"
              class="p-2 bg-neutral-100 hover:bg-pink-50 hover:text-pink-500 rounded-xl transition-colors"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-4 h-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <circle cx="11" cy="11" r="8"></circle><line
                  x1="21"
                  y1="21"
                  x2="16.65"
                  y2="16.65"></line>
                <line x1="11" y1="8" x2="11" y2="14"></line><line
                  x1="8"
                  y1="11"
                  x2="14"
                  y2="11"></line>
              </svg>
            </button>
            <button
              type="button"
              id="edit-zoom-out"
              class="p-2 bg-neutral-100 hover:bg-pink-50 hover:text-pink-500 rounded-xl transition-colors"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-4 h-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <circle cx="11" cy="11" r="8"></circle><line
                  x1="21"
                  y1="21"
                  x2="16.65"
                  y2="16.65"></line>
                <line x1="8" y1="11" x2="14" y2="11"></line>
              </svg>
            </button>
            <button
              type="button"
              id="edit-rotate-left"
              class="p-2 bg-neutral-100 hover:bg-pink-50 hover:text-pink-500 rounded-xl transition-colors"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-4 h-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <polyline points="1 4 1 10 7 10"></polyline><path
                  d="M3.51 15a9 9 0 1 0 .49-4.95"></path>
              </svg>
            </button>
            <button
              type="button"
              id="edit-rotate-right"
              class="p-2 bg-neutral-100 hover:bg-pink-50 hover:text-pink-500 rounded-xl transition-colors"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-4 h-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <polyline points="23 4 23 10 17 10"></polyline><path
                  d="M20.49 15a9 9 0 1 1-.49-4.95"></path>
              </svg>
            </button>
          </div>
        </div>

        <div class="flex flex-col gap-2">
          <label class="text-sm text-neutral-600">Titre / Alt</label>
          <input
            type="text"
            id="edit-alt"
            maxlength="100"
            class="border border-neutral-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-pink-400 transition-colors"
          />
        </div>

        <div class="flex flex-col gap-2">
          <label class="text-sm text-neutral-600"
            >Description <span class="text-neutral-400"
              >(max 300 caractères)</span
            ></label
          >
          <textarea
            id="edit-description"
            maxlength="300"
            rows="3"
            class="border border-neutral-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-pink-400 transition-colors resize-none"
          ></textarea>
          <span id="char-count" class="text-xs text-neutral-400 text-right"
            >0 / 300</span
          >
        </div>

        <div class="flex items-center gap-3 pb-2">
          <input
            type="checkbox"
            id="edit-featured"
            class="w-4 h-4 accent-pink-500"
          />
          <label for="edit-featured" class="text-sm text-neutral-600"
            >Mettre en vedette sur la page d'accueil</label
          >
        </div>
      </div>
      <div class="p-6 pt-4 border-t border-neutral-100">
        <button
          id="save-btn"
          class="w-full bg-pink-500 hover:bg-pink-600 text-white px-6 py-3 rounded-full text-sm transition-colors duration-200"
        >
          Enregistrer
        </button>
      </div>
    </div>
  </div>

  <!-- Modale upload -->
  <div
    id="upload-modal"
    class="hidden fixed inset-0 z-50 bg-black/50 backdrop-blur-sm flex items-center justify-center p-4"
  >
    <div
      class="bg-white rounded-2xl w-full max-w-md flex flex-col max-h-[90vh]"
    >
      <div class="flex items-center justify-between p-6 pb-4">
        <h2 class="text-lg font-serif text-neutral-800">Ajouter une photo</h2>
        <button
          id="close-upload"
          class="text-neutral-400 hover:text-pink-500 transition-colors"
          >✕</button
        >
      </div>
      <div class="flex flex-col gap-4 px-6 overflow-y-auto">
        <div
          id="drop-zone"
          class="border-2 border-dashed border-neutral-200 rounded-xl p-8 flex flex-col items-center gap-3 cursor-pointer hover:border-pink-400 hover:bg-pink-50/30 transition-colors"
        >
          <span class="text-3xl">📷</span>
          <p class="text-sm text-neutral-500 text-center">
            Glissez une photo ici ou cliquez pour sélectionner
          </p>
          <input
            type="file"
            id="upload-file-input"
            accept="image/*"
            class="hidden"
          />
        </div>

        <div id="upload-cropper-container" class="hidden flex flex-col gap-3">
          <div
            class="relative w-full bg-neutral-100 rounded-xl overflow-hidden"
            style="height: 280px;"
          >
            <img
              id="upload-cropper-image"
              src=""
              alt="Crop"
              class="max-w-full"
            />
          </div>
          <div class="flex items-center justify-center gap-2">
            <button
              type="button"
              id="upload-zoom-in"
              class="p-2 bg-neutral-100 hover:bg-pink-50 hover:text-pink-500 rounded-xl transition-colors"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-4 h-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <circle cx="11" cy="11" r="8"></circle><line
                  x1="21"
                  y1="21"
                  x2="16.65"
                  y2="16.65"></line>
                <line x1="11" y1="8" x2="11" y2="14"></line><line
                  x1="8"
                  y1="11"
                  x2="14"
                  y2="11"></line>
              </svg>
            </button>
            <button
              type="button"
              id="upload-zoom-out"
              class="p-2 bg-neutral-100 hover:bg-pink-50 hover:text-pink-500 rounded-xl transition-colors"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-4 h-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <circle cx="11" cy="11" r="8"></circle><line
                  x1="21"
                  y1="21"
                  x2="16.65"
                  y2="16.65"></line>
                <line x1="8" y1="11" x2="14" y2="11"></line>
              </svg>
            </button>
            <button
              type="button"
              id="upload-rotate-left"
              class="p-2 bg-neutral-100 hover:bg-pink-50 hover:text-pink-500 rounded-xl transition-colors"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-4 h-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <polyline points="1 4 1 10 7 10"></polyline><path
                  d="M3.51 15a9 9 0 1 0 .49-4.95"></path>
              </svg>
            </button>
            <button
              type="button"
              id="upload-rotate-right"
              class="p-2 bg-neutral-100 hover:bg-pink-50 hover:text-pink-500 rounded-xl transition-colors"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-4 h-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <polyline points="23 4 23 10 17 10"></polyline><path
                  d="M20.49 15a9 9 0 1 1-.49-4.95"></path>
              </svg>
            </button>
          </div>
        </div>

        <div class="flex flex-col gap-2">
          <label class="text-sm text-neutral-600">Titre / Alt</label>
          <input
            type="text"
            id="upload-alt"
            maxlength="100"
            placeholder="Ex: Robe de mariée sur mesure"
            class="border border-neutral-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-pink-400 transition-colors"
          />
        </div>

        <div class="flex flex-col gap-2">
          <label class="text-sm text-neutral-600"
            >Description <span class="text-neutral-400"
              >(max 300 caractères)</span
            ></label
          >
          <textarea
            id="upload-description"
            maxlength="300"
            rows="3"
            placeholder="Décrivez cette réalisation..."
            class="border border-neutral-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-pink-400 transition-colors resize-none"
          ></textarea>
        </div>

        <div class="flex items-center gap-3 pb-2">
          <input
            type="checkbox"
            id="upload-featured"
            class="w-4 h-4 accent-pink-500"
          />
          <label for="upload-featured" class="text-sm text-neutral-600"
            >Mettre en vedette sur la page d'accueil</label
          >
        </div>
      </div>
      <div class="p-6 pt-4 border-t border-neutral-100">
        <button
          id="upload-btn"
          class="w-full bg-pink-500 hover:bg-pink-600 text-white px-6 py-3 rounded-full text-sm transition-colors duration-200"
        >
          Ajouter à la liste
        </button>
      </div>
    </div>
  </div>

  <!-- Modale publication -->
  <div
    id="publish-modal"
    class="hidden fixed inset-0 z-50 bg-black/50 backdrop-blur-sm flex items-center justify-center p-4"
  >
    <div class="bg-white rounded-2xl w-full max-w-md flex flex-col gap-6 p-6">
      <h2 class="text-lg font-serif text-neutral-800">
        Modifications en attente
      </h2>

      <div
        id="publish-list"
        class="flex flex-col gap-2 max-h-60 overflow-y-auto"
      >
      </div>

      <div id="publish-status" class="hidden text-sm px-4 py-3 rounded-xl">
      </div>

      <div class="flex flex-col gap-2">
        <button
          id="publish-now-btn"
          class="w-full bg-pink-500 hover:bg-pink-600 text-white px-6 py-3 rounded-full text-sm transition-colors duration-200"
        >
          Publier maintenant
        </button>
        <button
          id="continue-btn"
          class="w-full border border-neutral-200 text-neutral-600 hover:border-pink-400 hover:text-pink-500 px-6 py-3 rounded-full text-sm transition-colors duration-200"
        >
          Continuer les modifications
        </button>
        <button
          id="cancel-all-btn"
          class="w-full text-red-500 hover:text-red-600 px-6 py-3 rounded-full text-sm transition-colors duration-200"
        >
          Annuler tout
        </button>
      </div>
    </div>
  </div>

  <!-- Modale succès publication -->
  <div
    id="success-modal"
    class="hidden fixed inset-0 z-50 bg-black/50 backdrop-blur-sm flex items-center justify-center p-4"
  >
    <div
      class="bg-white rounded-2xl w-full max-w-sm flex flex-col gap-6 p-6 text-center"
    >
      <div class="text-4xl">✓</div>
      <div class="flex flex-col gap-2">
        <h2 class="text-lg font-serif text-neutral-800">
          Modifications envoyées !
        </h2>
        <p class="text-sm text-neutral-500">
          Le site se mettra à jour dans environ 30 secondes.
        </p>
      </div>
      <div class="flex flex-col gap-2">
        <a
          href="/"
          target="_blank"
          id="see-site-btn"
          class="w-full bg-pink-500 hover:bg-pink-600 text-white px-6 py-3 rounded-full text-sm transition-colors duration-200 text-center"
        >
          Voir le site →
        </a>
        <button
          id="ok-btn"
          class="w-full border border-neutral-200 text-neutral-600 hover:border-pink-400 hover:text-pink-500 px-6 py-3 rounded-full text-sm transition-colors duration-200"
        >
          OK
        </button>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  import Cropper from "cropperjs";
  import "cropperjs/dist/cropper.css";

  // --- Types ---
  interface PendingImage {
    id: string;
    src: string;
    alt: string;
    description: string;
    featured: boolean;
    image?: string;
  }

  interface PendingStore {
    added: PendingImage[];
    updated: PendingImage[];
    deleted: { id: string; src: string; alt: string }[];
    originalImages: PendingImage[];
  }

  // --- Store localStorage ---
  const STORAGE_KEY = "creaticlo_pending";

  function getPending(): PendingStore {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return emptyStore();
      return JSON.parse(raw);
    } catch {
      return emptyStore();
    }
  }

  function savePending(store: PendingStore): void {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(store));
  }

  function clearPending(): void {
    localStorage.removeItem(STORAGE_KEY);
  }

  function emptyStore(): PendingStore {
    return { added: [], updated: [], deleted: [], originalImages: [] };
  }

  function countPending(store: PendingStore): number {
    return store.added.length + store.updated.length + store.deleted.length;
  }

  // --- UI helpers ---
  const publishBtn = document.getElementById(
    "publish-btn",
  ) as HTMLButtonElement;
  const publishBadge = document.getElementById(
    "publish-badge",
  ) as HTMLSpanElement;

  function updatePublishBtn() {
    const store = getPending();
    const count = countPending(store);
    if (count > 0) {
      publishBtn.disabled = false;
      publishBtn.className =
        "relative flex items-center gap-2 bg-pink-500 hover:bg-pink-600 text-white px-4 py-2 rounded-full text-sm transition-all duration-200 cursor-pointer";
      publishBadge.textContent = String(count);
      publishBadge.classList.remove("hidden");
    } else {
      publishBtn.disabled = true;
      publishBtn.className =
        "relative flex items-center gap-2 bg-neutral-100 text-neutral-400 px-4 py-2 rounded-full text-sm transition-all duration-200 disabled:cursor-not-allowed";
      publishBadge.classList.add("hidden");
    }
  }

  function refreshGrid() {
    const store = getPending();

    // Marque les cartes supprimées
    store.deleted.forEach(({ id }) => {
      const card = document.querySelector(`[data-id="${id}"]`) as HTMLElement;
      if (card) {
        card.style.opacity = "0.4";
        card.style.outline = "2px solid #ef4444";
      }
    });

    // Marque les cartes modifiées
    store.updated.forEach((img) => {
      const card = document.querySelector(
        `[data-id="${img.id}"]`,
      ) as HTMLElement;
      if (card) {
        card.style.outline = "2px solid #f59e0b";
        const altEl = card.querySelector("p");
        if (altEl) altEl.textContent = img.alt;
        // Met à jour le bookmark
        const featuredBtn = card.querySelector(
          ".featured-btn",
        ) as HTMLButtonElement;
        if (featuredBtn) {
          featuredBtn.setAttribute("data-featured", String(img.featured));
          const svg = featuredBtn.querySelector("svg") as SVGElement;
          if (svg) {
            svg.className.baseVal = img.featured
              ? "w-4 h-4 text-yellow-400 fill-yellow-400"
              : "w-4 h-4 text-yellow-400";
          }
        }
      }
    });

    // Ajoute les cartes nouvelles
    const grid = document.getElementById("gallery-grid") as HTMLDivElement;
    const uploadZone = document.getElementById("upload-zone") as HTMLDivElement;

    store.added.forEach((img) => {
      if (document.querySelector(`[data-id="${img.id}"]`)) return;

      const card = document.createElement("div");
      card.className =
        "bg-white rounded-2xl overflow-hidden shadow-sm border border-neutral-100";
      card.setAttribute("data-id", img.id);
      card.style.outline = "2px solid #22c55e";
      card.innerHTML = `
        <div class="aspect-[3/4] overflow-hidden">
          <img src="${img.image ?? img.src}" alt="${img.alt}" class="w-full h-full object-cover" />
        </div>
        <div class="p-3 flex flex-col gap-2">
          <p class="text-xs text-neutral-600 truncate">${img.alt}</p>
          <div class="flex items-center justify-around pt-1">
            <button class="edit-btn p-2 rounded-xl hover:bg-pink-50 transition-colors"
              data-id="${img.id}" data-alt="${img.alt}" data-description="${img.description}"
              data-featured="${img.featured}" data-src="${img.src}" title="Modifier">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-pink-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
              </svg>
            </button>
            <button class="delete-btn p-2 rounded-xl hover:bg-red-50 transition-colors"
              data-id="${img.id}" data-src="${img.src}" data-alt="${img.alt}" title="Supprimer">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-red-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="3 6 5 6 21 6"/>
                <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                <path d="M10 11v6M14 11v6"/>
                <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
              </svg>
            </button>
            <button class="featured-btn p-2 rounded-xl hover:bg-yellow-50 transition-colors"
              data-id="${img.id}" data-featured="${img.featured}"
              title="${img.featured ? "Retirer de la page d'accueil" : "Mettre en vedette"}">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 ${img.featured ? "text-yellow-400 fill-yellow-400" : "text-yellow-400"}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
              </svg>
            </button>
          </div>
        </div>
      `;
      grid.insertBefore(card, uploadZone);
      attachCardListeners(card);
    });
  }

  // --- Cropper ---
  let uploadCropper: Cropper | null = null;
  let editCropper: Cropper | null = null;

  const editModal = document.getElementById("edit-modal") as HTMLDivElement;
  const uploadModal = document.getElementById("upload-modal") as HTMLDivElement;
  const publishModal = document.getElementById(
    "publish-modal",
  ) as HTMLDivElement;
  const successModal = document.getElementById(
    "success-modal",
  ) as HTMLDivElement;

  function initCropper(
    imageEl: HTMLImageElement,
    src: string,
    cropperRef: "upload" | "edit",
  ) {
    imageEl.src = src;
    const cropper = new Cropper(imageEl, {
      aspectRatio: 3 / 4,
      viewMode: 1,
      dragMode: "move",
      autoCropArea: 1,
      restore: false,
      guides: true,
      center: true,
      highlight: false,
      cropBoxMovable: true,
      cropBoxResizable: false,
      toggleDragModeOnDblclick: false,
    });
    if (cropperRef === "upload") uploadCropper = cropper;
    else editCropper = cropper;

    document
      .getElementById(`${cropperRef}-zoom-in`)
      ?.addEventListener("click", () => cropper.zoom(0.1));
    document
      .getElementById(`${cropperRef}-zoom-out`)
      ?.addEventListener("click", () => cropper.zoom(-0.1));
    document
      .getElementById(`${cropperRef}-rotate-left`)
      ?.addEventListener("click", () => cropper.rotate(-90));
    document
      .getElementById(`${cropperRef}-rotate-right`)
      ?.addEventListener("click", () => cropper.rotate(90));
  }

  // --- Logout ---
  document.getElementById("logout-btn")?.addEventListener("click", async () => {
    const store = getPending();
    if (countPending(store) > 0) {
      const confirmed = confirm(
        `Vous avez ${countPending(store)} modification(s) non publiée(s). Voulez-vous vraiment vous déconnecter ?`,
      );
      if (!confirmed) return;
    }
    await fetch("/api/admin/logout", { method: "POST" });
    window.location.href = "/admin";
  });

  // --- Fermeture modales ---
  document.getElementById("close-edit")?.addEventListener("click", () => {
    editModal.classList.add("hidden");
    if (editCropper) {
      editCropper.destroy();
      editCropper = null;
    }
  });

  document.getElementById("close-upload")?.addEventListener("click", () => {
    uploadModal.classList.add("hidden");
    if (uploadCropper) {
      uploadCropper.destroy();
      uploadCropper = null;
    }
  });

  // --- Upload ---
  const uploadFileInput = document.getElementById(
    "upload-file-input",
  ) as HTMLInputElement;
  const uploadDropZone = document.getElementById("drop-zone") as HTMLDivElement;
  const uploadCropperImage = document.getElementById(
    "upload-cropper-image",
  ) as HTMLImageElement;
  const uploadCropperContainer = document.getElementById(
    "upload-cropper-container",
  ) as HTMLDivElement;

  document.getElementById("upload-zone")?.addEventListener("click", () => {
    uploadModal.classList.remove("hidden");
  });

  uploadDropZone.addEventListener("click", () => uploadFileInput.click());

  uploadDropZone.addEventListener("dragover", (e) => {
    e.preventDefault();
    uploadDropZone.classList.add("border-pink-400", "bg-pink-50/30");
  });

  uploadDropZone.addEventListener("dragleave", () => {
    uploadDropZone.classList.remove("border-pink-400", "bg-pink-50/30");
  });

  uploadDropZone.addEventListener("drop", (e) => {
    e.preventDefault();
    const file = (e as DragEvent).dataTransfer?.files[0];
    if (file) handleUploadFile(file);
  });

  uploadFileInput.addEventListener("change", () => {
    const file = uploadFileInput.files?.[0];
    if (file) handleUploadFile(file);
  });

  function handleUploadFile(file: File) {
    if (uploadCropper) {
      uploadCropper.destroy();
      uploadCropper = null;
    }
    const reader = new FileReader();
    reader.onload = (e) => {
      uploadCropperContainer.classList.remove("hidden");
      uploadDropZone.classList.add("hidden");
      initCropper(uploadCropperImage, e.target?.result as string, "upload");
    };
    reader.readAsDataURL(file);
  }

  document.getElementById("upload-btn")?.addEventListener("click", () => {
    const alt = (document.getElementById("upload-alt") as HTMLInputElement)
      .value;
    const description = (
      document.getElementById("upload-description") as HTMLTextAreaElement
    ).value;
    const featured = (
      document.getElementById("upload-featured") as HTMLInputElement
    ).checked;

    if (!uploadCropper || !alt) {
      alert("Veuillez sélectionner une photo et renseigner un titre.");
      return;
    }

    const canvas = uploadCropper.getCroppedCanvas({ width: 800, height: 1067 });
    const base64 = canvas.toDataURL("image/jpeg", 0.85);
    const id = Date.now().toString();
    const src = `/images/gallery/gallery-${id}.jpg`;

    const store = getPending();
    store.added.push({ id, src, alt, description, featured, image: base64 });
    savePending(store);

    uploadModal.classList.add("hidden");
    uploadCropper.destroy();
    uploadCropper = null;

    // Reset modale
    uploadCropperContainer.classList.add("hidden");
    uploadDropZone.classList.remove("hidden");
    (document.getElementById("upload-alt") as HTMLInputElement).value = "";
    (
      document.getElementById("upload-description") as HTMLTextAreaElement
    ).value = "";
    (document.getElementById("upload-featured") as HTMLInputElement).checked =
      false;
    uploadFileInput.value = "";

    updatePublishBtn();
    refreshGrid();
  });

  // --- Edit ---
  const editCropperImage = document.getElementById(
    "edit-cropper-image",
  ) as HTMLImageElement;
  const editCropperContainer = document.getElementById(
    "edit-cropper-container",
  ) as HTMLDivElement;
  const editFileInput = document.getElementById(
    "edit-file-input",
  ) as HTMLInputElement;
  let currentEditSrc = "";

  function attachCardListeners(container: Element | Document) {
    container.querySelectorAll(".edit-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const id = btn.getAttribute("data-id")!;
        const alt = btn.getAttribute("data-alt")!;
        const description = btn.getAttribute("data-description")!;
        const featured = btn.getAttribute("data-featured") === "true";
        const src = btn.getAttribute("data-src")!;

        currentEditSrc = src;
        (document.getElementById("edit-id") as HTMLInputElement).value = id;
        (document.getElementById("edit-alt") as HTMLInputElement).value = alt;
        (
          document.getElementById("edit-description") as HTMLTextAreaElement
        ).value = description;
        (document.getElementById("edit-featured") as HTMLInputElement).checked =
          featured;
        document.getElementById("char-count")!.textContent =
          `${description.length} / 300`;

        if (editCropper) {
          editCropper.destroy();
          editCropper = null;
        }
        editCropperContainer.classList.add("hidden");
        editFileInput.value = "";

        editModal.classList.remove("hidden");
      });
    });

    container.querySelectorAll(".delete-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const id = btn.getAttribute("data-id")!;
        const src = btn.getAttribute("data-src")!;
        const alt = btn.getAttribute("data-alt")!;

        const confirmed = confirm(
          `Supprimer "${alt}" ? Cette action sera effective après publication.`,
        );
        if (!confirmed) return;

        const store = getPending();

        // Si c'est une image ajoutée non publiée, on la retire juste du store
        const addedIndex = store.added.findIndex((i) => i.id === id);
        if (addedIndex !== -1) {
          store.added.splice(addedIndex, 1);
          savePending(store);
          const card = document.querySelector(`[data-id="${id}"]`);
          card?.remove();
          updatePublishBtn();
          return;
        }

        store.deleted.push({ id, src, alt });
        savePending(store);
        updatePublishBtn();
        refreshGrid();
      });
    });

    container.querySelectorAll(".featured-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const id = btn.getAttribute("data-id")!;
        const featured = btn.getAttribute("data-featured") === "true";
        const src = btn.getAttribute("data-src") || currentEditSrc;

        const store = getPending();

        // Vérifie si déjà dans updated
        const existingIndex = store.updated.findIndex((i) => i.id === id);
        if (existingIndex !== -1) {
          store.updated[existingIndex].featured = !featured;
        } else {
          // Récupère les données actuelles depuis le DOM
          const card = document.querySelector(`[data-id="${id}"]`);
          const alt = card?.querySelector("p")?.textContent || "";
          const editBtn = card?.querySelector(".edit-btn");
          const description = editBtn?.getAttribute("data-description") || "";
          store.updated.push({
            id,
            src: src || "",
            alt,
            description,
            featured: !featured,
          });
        }

        btn.setAttribute("data-featured", String(!featured));
        savePending(store);
        updatePublishBtn();
        refreshGrid();
      });
    });
  }

  // Attache les listeners aux cartes existantes
  attachCardListeners(document);

  document
    .getElementById("edit-change-photo")
    ?.addEventListener("click", () => editFileInput.click());

  editFileInput.addEventListener("change", () => {
    const file = editFileInput.files?.[0];
    if (!file) return;
    if (editCropper) {
      editCropper.destroy();
      editCropper = null;
    }
    const reader = new FileReader();
    reader.onload = (e) => {
      editCropperContainer.classList.remove("hidden");
      initCropper(editCropperImage, e.target?.result as string, "edit");
    };
    reader.readAsDataURL(file);
  });

  document
    .getElementById("edit-description")
    ?.addEventListener("input", (e) => {
      const val = (e.target as HTMLTextAreaElement).value;
      document.getElementById("char-count")!.textContent =
        `${val.length} / 300`;
    });

  document.getElementById("save-btn")?.addEventListener("click", () => {
    const id = (document.getElementById("edit-id") as HTMLInputElement).value;
    const alt = (document.getElementById("edit-alt") as HTMLInputElement).value;
    const description = (
      document.getElementById("edit-description") as HTMLTextAreaElement
    ).value;
    const featured = (
      document.getElementById("edit-featured") as HTMLInputElement
    ).checked;

    const store = getPending();

    let imageBase64: string | undefined;
    if (editCropper) {
      const canvas = editCropper.getCroppedCanvas({ width: 800, height: 1067 });
      imageBase64 = canvas.toDataURL("image/jpeg", 0.85);
    }

    // Vérifie si c'est une image ajoutée non publiée
    const addedIndex = store.added.findIndex((i) => i.id === id);
    if (addedIndex !== -1) {
      store.added[addedIndex] = {
        ...store.added[addedIndex],
        alt,
        description,
        featured,
        ...(imageBase64 ? { image: imageBase64 } : {}),
      };
    } else {
      const existingIndex = store.updated.findIndex((i) => i.id === id);
      if (existingIndex !== -1) {
        store.updated[existingIndex] = {
          ...store.updated[existingIndex],
          alt,
          description,
          featured,
          ...(imageBase64 ? { image: imageBase64 } : {}),
        };
      } else {
        store.updated.push({
          id,
          src: currentEditSrc,
          alt,
          description,
          featured,
          ...(imageBase64 ? { image: imageBase64 } : {}),
        });
      }
    }

    savePending(store);
    editModal.classList.add("hidden");
    if (editCropper) {
      editCropper.destroy();
      editCropper = null;
    }

    // Met à jour les data attributes du bouton edit
    const editBtn = document.querySelector(`[data-id="${id}"] .edit-btn`);
    if (editBtn) {
      editBtn.setAttribute("data-alt", alt);
      editBtn.setAttribute("data-description", description);
      editBtn.setAttribute("data-featured", String(featured));
    }

    updatePublishBtn();
    refreshGrid();
  });

  // --- Publish ---
  publishBtn.addEventListener("click", () => {
    const store = getPending();
    const publishList = document.getElementById(
      "publish-list",
    ) as HTMLDivElement;
    publishList.innerHTML = "";

    store.added.forEach((img) => {
      const el = document.createElement("div");
      el.className =
        "flex items-center gap-3 text-sm p-2 bg-green-50 rounded-xl";
      el.innerHTML = `<span class="text-green-500 font-bold">✚</span><span class="text-neutral-700">${img.alt}</span><span class="text-green-500 text-xs ml-auto">Ajout</span>`;
      publishList.appendChild(el);
    });

    store.updated.forEach((img) => {
      const el = document.createElement("div");
      el.className =
        "flex items-center gap-3 text-sm p-2 bg-yellow-50 rounded-xl";
      el.innerHTML = `<span class="text-yellow-500 font-bold">✎</span><span class="text-neutral-700">${img.alt}</span><span class="text-yellow-500 text-xs ml-auto">Modification</span>`;
      publishList.appendChild(el);
    });

    store.deleted.forEach((img) => {
      const el = document.createElement("div");
      el.className = "flex items-center gap-3 text-sm p-2 bg-red-50 rounded-xl";
      el.innerHTML = `<span class="text-red-500 font-bold">✕</span><span class="text-neutral-700">${img.alt}</span><span class="text-red-500 text-xs ml-auto">Suppression</span>`;
      publishList.appendChild(el);
    });

    publishModal.classList.remove("hidden");
  });

  document.getElementById("continue-btn")?.addEventListener("click", () => {
    publishModal.classList.add("hidden");
  });

  document.getElementById("cancel-all-btn")?.addEventListener("click", () => {
    const confirmed = confirm(
      "Annuler toutes les modifications ? Cette action est irréversible.",
    );
    if (!confirmed) return;
    clearPending();
    publishModal.classList.add("hidden");
    window.location.reload();
  });

  document
    .getElementById("publish-now-btn")
    ?.addEventListener("click", async () => {
      const store = getPending();
      const btn = document.getElementById(
        "publish-now-btn",
      ) as HTMLButtonElement;
      const status = document.getElementById(
        "publish-status",
      ) as HTMLDivElement;

      btn.textContent = "Publication en cours...";
      btn.disabled = true;

      const response = await fetch("/api/admin/publish", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          added: store.added,
          updated: store.updated,
          deleted: store.deleted,
        }),
      });

      if (response.ok) {
        clearPending();
        publishModal.classList.add("hidden");
        successModal.classList.remove("hidden");
        startCountdown();
      } else {
        status.className =
          "text-sm px-4 py-3 rounded-xl bg-red-50 text-red-600";
        status.textContent = "✗ Une erreur est survenue. Réessayez.";
        status.classList.remove("hidden");
      }

      btn.textContent = "Publier maintenant";
      btn.disabled = false;
    });

  document.getElementById("ok-btn")?.addEventListener("click", async () => {
    await fetch("/api/admin/logout", { method: "POST" });
    window.location.href = "/admin";
  });
  document.getElementById("ok-btn")?.addEventListener("click", async () => {
    await fetch("/api/admin/logout", { method: "POST" });
    window.location.href = "/admin";
  });

  // Compte à rebours sur le bouton "Voir le site"
  const seeSiteBtn = document.getElementById(
    "see-site-btn",
  ) as HTMLAnchorElement;

  function startCountdown() {
    let seconds = 30;
    seeSiteBtn.style.pointerEvents = "none";
    seeSiteBtn.classList.remove("bg-pink-500", "hover:bg-pink-600");
    seeSiteBtn.classList.add("bg-neutral-200", "text-neutral-400");

    const interval = setInterval(() => {
      seconds--;
      seeSiteBtn.textContent = `Voir le site dans ${seconds}s →`;
      if (seconds <= 0) {
        clearInterval(interval);
        seeSiteBtn.textContent = "Voir le site →";
        seeSiteBtn.style.pointerEvents = "auto";
        seeSiteBtn.classList.remove("bg-neutral-200", "text-neutral-400");
        seeSiteBtn.classList.add("bg-pink-500", "hover:bg-pink-600");
      }
    }, 1000);
  }

  // --- Warning refresh ---
  window.addEventListener("beforeunload", (e) => {
    const store = getPending();
    if (countPending(store) > 0) {
      e.preventDefault();
    }
  });

  // --- Init ---
  updatePublishBtn();
  refreshGrid();
</script>
