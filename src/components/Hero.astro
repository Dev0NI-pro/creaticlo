---

<section id="hero" class="min-h-screen pt-16 py-16 md:py-0 flex items-center">
  <div class="max-w-6xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
    <!-- Texte -->
    <div class="flex flex-col gap-6">
      <h1 class="text-5xl font-serif leading-tight text-neutral-800">
        L'Art du <em class="text-pink-500 not-italic">Parfait</em> Ajustement.
      </h1>
      <p class="text-neutral-500 text-lg leading-relaxed">
        Tailleur sur mesure et retouches expertes beauté la finesse de
        l'excellence fait-main. Nous transformons le vêtement en une pièce
        unique et personnelle.
      </p>
      <div class="flex items-center gap-4">
        <a
          href="#contact"
          class="bg-pink-500 hover:bg-pink-600 text-white px-6 py-3 rounded-full text-sm transition-colors duration-200"
        >
          Prendre rendez-vous
        </a>
        <a
          href="#gallery"
          class="text-sm text-neutral-600 hover:text-pink-500 transition-colors duration-200 underline underline-offset-4"
        >
          Voir le travail
        </a>
      </div>
    </div>

    <!-- Image -->
    <div class="relative hidden md:block">
      <img
        src="/images/hero.jpg"
        alt="Couturière travaillant sur une pièce sur mesure"
        class="w-full h-[600px] object-cover rounded-2xl"
      />
    </div>
  </div>
</section>
