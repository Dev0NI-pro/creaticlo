---
---

<div id="cropper-container" class="hidden flex flex-col gap-4">
  <!-- Zone de crop -->
  <div class="relative w-full bg-neutral-100 rounded-xl overflow-hidden" style="height: 300px;">
    <img id="cropper-image" src="" alt="Crop" class="max-w-full" />
  </div>

  <!-- Actions crop -->
  <div class="flex items-center justify-center gap-3">
    <button type="button" id="crop-zoom-in" class="p-2 bg-neutral-100 hover:bg-pink-50 hover:text-pink-500 rounded-xl transition-colors text-sm">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        <line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/>
      </svg>
    </button>
    <button type="button" id="crop-zoom-out" class="p-2 bg-neutral-100 hover:bg-pink-50 hover:text-pink-500 rounded-xl transition-colors text-sm">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        <line x1="8" y1="11" x2="14" y2="11"/>
      </svg>
    </button>
    <button type="button" id="crop-rotate-left" class="p-2 bg-neutral-100 hover:bg-pink-50 hover:text-pink-500 rounded-xl transition-colors text-sm">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4.95"/>
      </svg>
    </button>
    <button type="button" id="crop-rotate-right" class="p-2 bg-neutral-100 hover:bg-pink-50 hover:text-pink-500 rounded-xl transition-colors text-sm">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-.49-4.95"/>
      </svg>
    </button>
  </div>
</div>