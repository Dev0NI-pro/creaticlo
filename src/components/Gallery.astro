---
const images = [
    { src: "/images/gallery-1.jpg", alt: "Robe de mariée sur mesure" },
    { src: "/images/gallery-2.jpg", alt: "Manteau en laine ajusté" },
    { src: "/images/gallery-3.jpg", alt: "Robe en soie" },
    {
        src: "/images/gallery-4.jpg",
        alt: "Sac a main en daim sur une table en bois",
    },
    { src: "/images/gallery-5.jpg", alt: "Pantalon recousu" },
    { src: "/images/gallery-6.jpg", alt: "Robe de soirée typée fantasy" },
];
---

<section id="gallery" class="py-24 bg-neutral-50">
    <div class="max-w-6xl mx-auto px-6 flex flex-col gap-12">
        <!-- Titre -->
        <div class="flex items-end justify-between">
            <div class="flex flex-col gap-4">
                <span class="text-pink-500 text-sm font-medium tracking-widest uppercase">
                    Nos réalisations
                </span>
                <h2 class="text-4xl font-serif text-neutral-800">
                    La Collection de l'Atelier
                </h2>
                <p class="text-neutral-500 leading-relaxed">
                    Un aperçu de nos travaux récents et de nos transformations
                    créatives.
                </p>
            </div>

            <!-- CTA -->
            <a class="hidden md:flex items-center gap-2 text-sm text-neutral-600 hover:text-pink-500 transition-colors duration-200 cursor-not-allowed">
                Voir plus<span>→</span>
            </a>
        </div>

        <!-- Grille -->
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
            {
                images.map(({ src, alt }) => (
                    <div class="overflow-hidden rounded-2xl aspect-[3/4]">
                        <img
                            src={src}
                            alt={alt}
                            class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                        />
                    </div>
                ))
            }
        </div>
    </div>
</section>
