---
import galleryData from "../data/gallery.json";

const featured = galleryData.images.filter((img) => img.featured);
---

<section id="gallery" class="py-24 bg-neutral-50">
    <div class="max-w-6xl mx-auto px-6 flex flex-col gap-12">
        <!-- Titre + CTA -->
        <div
            class="flex flex-col md:flex-row md:items-end md:justify-between gap-4"
        >
            <div class="flex flex-col gap-4">
                <span
                    class="text-pink-500 text-sm font-medium tracking-widest uppercase"
                >
                    Nos réalisations
                </span>
                <h2 class="text-4xl font-serif text-neutral-800">
                    La Collection de l'Atelier
                </h2>
                <p class="text-neutral-500 leading-relaxed">
                    Un aperçu de nos travaux récents et de nos transformations
                    créatives.
                </p>
            </div>
            
            <!-- CTA desktop -->
            <a href="/gallery" class="hidden md:flex items-center gap-2 text-sm text-neutral-600 hover:text-pink-500 transition-colors duration-200">
                Voir plus <span>→</span>
            </a>
        </div>

        <!-- Grille -->
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
            {
                featured.map(({ src, alt }) => (
                    <div class="overflow-hidden rounded-2xl aspect-[3/4]">
                        <img
                            src={src}
                            alt={alt}
                            class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                        />
                    </div>
                ))
            }
        </div>

        <!-- CTA mobile -->
        <div class="flex md:hidden justify-center">
            <a
                href="/gallery"
                class="flex items-center gap-2 text-sm text-pink-500 border border-pink-500 px-6 py-3 rounded-full"
            >
                Voir toutes les réalisations
                <span>→</span>
            </a>
        </div>
    </div>
</section>
