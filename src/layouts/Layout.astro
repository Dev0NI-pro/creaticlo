---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "L'Atelier — Couturière sur mesure",
  description = "Retouches, confection et réparations sur mesure. Découvrez le savoir-faire artisanal de notre atelier.",
} = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="antialiased text-neutral-800 bg-white">
    <slot />
  </body>
</html>